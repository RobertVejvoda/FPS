        "type": "object",
        "properties": {
          "drawKey": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "requestCount": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
